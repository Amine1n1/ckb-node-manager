{
  "name": "ckb-node-manager",
  "private": true,
  "version": "1.0.0",
  "homepage": "https://Amine1n1.github.io/ckb-node-manager",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron:dev": "NODE_ENV=development electron .",
    "build": "vite build",
    "build:server": "esbuild backend/server.js --bundle --platform=node --format=cjs --define:import.meta.url=__importMetaUrl --banner:js=\"const __importMetaUrl = require('url').pathToFileURL(__filename).href;\" --outfile=backend-dist/server.js",
    "build:mac": "vite build && npm run build:server && electron-builder --mac",
    "build:win": "vite build && npm run build:server && electron-builder --win",
    "build:linux": "vite build && npm run build:server && electron-builder --linux",
    "release:mac": "vite build && electron-builder --mac --publish always",
    "release:win": "vite build && electron-builder --win --publish always",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server.js",
    "client": "react-scripts start",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -r git@github.com:Amine1n1/ckb-node-manager.git"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.0"
  },
  "build": {
    "appId": "com.amga.ckb-node-manager",
    "productName": "CKB Node Manager",
    "icon": "build/icon",
    "publish": [
      {
        "provider": "github",
        "owner": "Amine1n1",
        "repo": "ckb-node-manager",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist-react/**/*",
      "dist-electron/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
    {
    "from": "backend-dist/",
    "to": "backend-dist/"
    },
    {
    "from": "ckb-bins/",
    "to": "ckb-bins/"
    },
    {
    "from": "ckb-templates/",
    "to": "ckb-templates/"
    }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "executableName": "CKB Node Manager"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CKB Node Manager"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.1"
  },
  "description": "This template provides a minimal setup to get React working in Vite with HMR and some ESLint rules.",
  "main": "electron/main.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
